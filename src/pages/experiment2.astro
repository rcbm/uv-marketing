    </div>

    <script is:inline>
      (function () {
        var CELL = 10;
        var LEVELS = 16;
        var chars = [' ', '.', '\u00B7', ':', '-', '=', '+', '*', '#', '%', '\u2591', '\u2592', '\u2593', '\u2588', '\u2588', '\u2588'];

        function grayColor(level) {
          var t = level / (LEVELS - 1);
          var base = Math.round(10 + t * 170);
          var r = Math.round(base * (0.95 + t * 0.05));
          var g = Math.round(base * (0.97 + t * 0.01));
          var b = Math.round(base * (1.0 + (1 - t) * 0.06));
          if (r > 255) r = 255;
          if (g > 255) g = 255;
          if (b > 255) b = 255;
          return 'rgb(' + r + ',' + g + ',' + b + ')';
        }

        var grays = [];
        for (var i = 0; i < LEVELS; i++) grays[i] = grayColor(i);

        var bayer4 = [
          [ 0,  8,  2, 10],
          [12,  4, 14,  6],
          [ 3, 11,  1,  9],
          [15,  7, 13,  5]
        ];
        for (var r = 0; r < 4; r++)
          for (var c = 0; c < 4; c++)
            bayer4[r][c] = (bayer4[r][c] + 0.5) / 16.0;

        function dither(val, col, row) {
          var threshold = bayer4[row & 3][col & 3];
          var scaled = val * (LEVELS - 1);
          var base = Math.floor(scaled);
          var frac = scaled - base;
          var level = frac > threshold ? base + 1 : base;
          if (level < 0) level = 0;
          if (level >= LEVELS) level = LEVELS - 1;
          return level;
        }

        var instances = [];

        function initCanvas(canvas) {
          var ctx = canvas.getContext('2d');
          var parent = canvas.parentElement;
          var anim = canvas.getAttribute('data-anim');
          var obj = { canvas: canvas, ctx: ctx, parent: parent, anim: anim, cols: 0, rows: 0, visible: false, state: {} };

          if (anim === 'reaction') {
            obj.state.gridA = null;
            obj.state.gridB = null;
            obj.state.simW = 0;
            obj.state.simH = 0;
          }
          if (anim === 'lissajous') {
            obj.state.trail = null;
          }
          if (anim === 'voronoi') {
            obj.state.seeds = [];
            for (var i = 0; i < 20; i++) {
              obj.state.seeds.push({
                x: Math.random(), y: Math.random(),
                vx: (Math.random() - 0.5) * 0.3,
                vy: (Math.random() - 0.5) * 0.3
              });
            }
          }

          instances.push(obj);
          sizeCanvas(obj);
          return obj;
        }

        function sizeCanvas(obj) {
          var dpr = window.devicePixelRatio || 1;
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          obj.canvas.width = w * dpr;
          obj.canvas.height = h * dpr;
          obj.canvas.style.width = w + 'px';
          obj.canvas.style.height = h + 'px';
          obj.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          obj.cols = Math.ceil(w / CELL) + 1;
          obj.rows = Math.ceil(h / CELL) + 1;

          if (obj.anim === 'reaction') {
            var simW = Math.ceil(obj.cols / 2);
            var simH = Math.ceil(obj.rows / 2);
            var total = simW * simH;
            obj.state.simW = simW;
            obj.state.simH = simH;
            obj.state.gridA = new Float32Array(total);
            obj.state.gridB = new Float32Array(total);
            for (var i = 0; i < total; i++) {
              obj.state.gridA[i] = 1.0;
              obj.state.gridB[i] = 0.0;
            }
            for (var k = 0; k < 5; k++) {
              var sx = Math.floor(Math.random() * simW);
              var sy = Math.floor(Math.random() * simH);
              for (var dy = -3; dy <= 3; dy++) {
                for (var dx = -3; dx <= 3; dx++) {
                  var nx = (sx + dx + simW) % simW;
                  var ny = (sy + dy + simH) % simH;
                  obj.state.gridB[ny * simW + nx] = 1.0;
                }
              }
            }
          }
          if (obj.anim === 'lissajous') {
            obj.state.trail = new Float32Array(obj.cols * obj.rows);
          }
        }

        function charRender(ctx, w, h, cols, rows, valueFn) {
          ctx.clearRect(0, 0, w, h);
          var buckets = [];
          for (var i = 0; i < LEVELS; i++) buckets[i] = [];
          for (var r = 0; r < rows; r++) {
            for (var c = 0; c < cols; c++) {
              var val = valueFn(c, r, cols, rows);
              if (val < 0) val = 0; if (val > 1) val = 1;
              var level = dither(val, c, r);
              buckets[level].push(c * CELL, r * CELL);
            }
          }
          ctx.font = CELL + 'px Oxygen Mono, monospace';
          ctx.textBaseline = 'top';
          for (var lvl = 0; lvl < LEVELS; lvl++) {
            if (buckets[lvl].length === 0) continue;
            ctx.fillStyle = grays[lvl];
            var ch = chars[lvl];
            var arr = buckets[lvl];
            for (var j = 0; j < arr.length; j += 2) {
              ctx.fillText(ch, arr[j], arr[j + 1]);
            }
          }
        }

        function pixelRender(ctx, w, h, cols, rows, valueFn) {
          ctx.clearRect(0, 0, w, h);
          var buckets = [];
          for (var i = 0; i < LEVELS; i++) buckets[i] = [];
          for (var r = 0; r < rows; r++) {
            for (var c = 0; c < cols; c++) {
              var val = valueFn(c, r, cols, rows);
              if (val < 0) val = 0; if (val > 1) val = 1;
              var level = dither(val, c, r);
              buckets[level].push(c * CELL, r * CELL);
            }
          }
          for (var lvl = 0; lvl < LEVELS; lvl++) {
            if (buckets[lvl].length === 0) continue;
            ctx.fillStyle = grays[lvl];
            var arr = buckets[lvl];
            for (var j = 0; j < arr.length; j += 2) {
              ctx.fillRect(arr[j], arr[j + 1], CELL, CELL);
            }
          }
        }

        // 1. Plasma — classic demoscene summed sines
        function drawPlasma(obj, s) {
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          var cx = 0.5 + Math.sin(s * 0.3) * 0.3;
          var cy = 0.5 + Math.cos(s * 0.23) * 0.3;
          charRender(obj.ctx, w, h, obj.cols, obj.rows, function (c, r, cols, rows) {
            var x = c / cols;
            var y = r / rows;
            var v1 = Math.sin(x * 10.0 + s * 0.7);
            var v2 = Math.sin(y * 8.0 + s * 0.5);
            var v3 = Math.sin((x + y) * 6.0 + s * 0.4);
            var dx = x - cx, dy = y - cy;
            var dist = Math.sqrt(dx * dx + dy * dy);
            var v4 = Math.sin(dist * 14.0 - s * 0.9);
            var v5 = Math.sin(x * 5.0 * Math.sin(s * 0.15) + y * 4.0 * Math.cos(s * 0.12));
            return (v1 + v2 + v3 + v4 + v5) / 10.0 + 0.5;
          });
        }

        // 2. Topographic Contours — multi-octave noise with contour bands
        var permutation = [];
        (function () {
          var p = [];
          for (var i = 0; i < 256; i++) p[i] = i;
          for (var i = 255; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var tmp = p[i]; p[i] = p[j]; p[j] = tmp;
          }
          for (var i = 0; i < 512; i++) permutation[i] = p[i & 255];
        })();

        function fade(t) { return t * t * t * (t * (t * 6 - 15) + 10); }
        function lerp(a, b, t) { return a + t * (b - a); }
        function grad(hash, x, y) {
          var h = hash & 3;
          var u = h < 2 ? x : y;
          var v = h < 2 ? y : x;
          return ((h & 1) ? -u : u) + ((h & 2) ? -v : v);
        }
        function perlin(x, y) {
          var X = Math.floor(x) & 255, Y = Math.floor(y) & 255;
          x -= Math.floor(x); y -= Math.floor(y);
          var u = fade(x), v = fade(y);
          var A = permutation[X] + Y, B = permutation[X + 1] + Y;
          return lerp(
            lerp(grad(permutation[A], x, y), grad(permutation[B], x - 1, y), u),
            lerp(grad(permutation[A + 1], x, y - 1), grad(permutation[B + 1], x - 1, y - 1), u),
            v
          );
        }
        function fbm(x, y, octaves) {
          var val = 0, amp = 0.5, freq = 1;
          for (var i = 0; i < octaves; i++) {
            val += amp * perlin(x * freq, y * freq);
            amp *= 0.5;
            freq *= 2;
          }
          return val;
        }

        function drawTopo(obj, s) {
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          var drift = s * 0.08;
          pixelRender(obj.ctx, w, h, obj.cols, obj.rows, function (c, r, cols, rows) {
            var x = c / cols * 6.0 + drift;
            var y = r / rows * 6.0 + drift * 0.7;
            var n = fbm(x, y, 5) * 0.5 + 0.5;
            var bands = 12;
            var band = Math.floor(n * bands) / bands;
            var frac = (n * bands) - Math.floor(n * bands);
            var edge = (frac < 0.06 || frac > 0.94) ? 0.9 : 0.0;
            return band * 0.7 + edge * 0.3;
          });
        }

        // 3. Moire Interference — two radial grids counter-rotating
        function drawMoire(obj, s) {
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          var a1 = s * 0.15;
          var a2 = -s * 0.12;
          charRender(obj.ctx, w, h, obj.cols, obj.rows, function (c, r, cols, rows) {
            var x = c / cols - 0.5;
            var y = r / rows - 0.5;
            var x1 = x * Math.cos(a1) - y * Math.sin(a1);
            var y1 = x * Math.sin(a1) + y * Math.cos(a1);
            var g1 = (Math.sin(x1 * 40.0) * 0.5 + 0.5) * (Math.sin(y1 * 40.0) * 0.5 + 0.5);
            var x2 = x * Math.cos(a2) - y * Math.sin(a2);
            var y2 = x * Math.sin(a2) + y * Math.cos(a2);
            var g2 = (Math.sin(x2 * 42.0) * 0.5 + 0.5) * (Math.sin(y2 * 42.0) * 0.5 + 0.5);
            return (g1 + g2) * 0.5;
          });
        }

        // 4. Tunnel Zoom — pseudo-3D wormhole via polar mapping
        function drawTunnel(obj, s) {
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          var aspect = h / w;
          pixelRender(obj.ctx, w, h, obj.cols, obj.rows, function (c, r, cols, rows) {
            var x = (c / cols - 0.5) * 2.0;
            var y = (r / rows - 0.5) * 2.0 * aspect;
            var dist = Math.sqrt(x * x + y * y);
            if (dist < 0.001) dist = 0.001;
            var angle = Math.atan2(y, x);
            var depth = 1.0 / dist;
            var u = angle / Math.PI;
            var v = depth + s * 0.5;
            var tex = Math.sin(u * 8.0 + v * 3.0) * Math.sin(v * 5.0 - u * 2.0);
            var brightness = (tex * 0.5 + 0.5) * Math.min(depth * 0.3, 1.0);
            brightness *= 1.0 - Math.min(dist * 0.5, 0.6);
            return brightness;
          });
        }

        // 5. Reaction-Diffusion — Gray-Scott model
        function stepReaction(state) {
          var w = state.simW, h = state.simH;
          var A = state.gridA, B = state.gridB;
          var dA = 1.0, dB = 0.5, feed = 0.055, kill = 0.062;
          var newA = new Float32Array(w * h);
          var newB = new Float32Array(w * h);
          for (var y = 0; y < h; y++) {
            for (var x = 0; x < w; x++) {
              var idx = y * w + x;
              var a = A[idx], b = B[idx];
              var up = ((y - 1 + h) % h) * w + x;
              var dn = ((y + 1) % h) * w + x;
              var lt = y * w + ((x - 1 + w) % w);
              var rt = y * w + ((x + 1) % w);
              var lapA = A[up] + A[dn] + A[lt] + A[rt] - 4 * a;
              var lapB = B[up] + B[dn] + B[lt] + B[rt] - 4 * b;
              var abb = a * b * b;
              newA[idx] = a + (dA * lapA - abb + feed * (1.0 - a)) * 0.9;
              newB[idx] = b + (dB * lapB + abb - (kill + feed) * b) * 0.9;
              if (newA[idx] < 0) newA[idx] = 0; if (newA[idx] > 1) newA[idx] = 1;
              if (newB[idx] < 0) newB[idx] = 0; if (newB[idx] > 1) newB[idx] = 1;
            }
          }
          state.gridA = newA;
          state.gridB = newB;
        }

        function drawReaction(obj, s) {
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          var state = obj.state;
          if (!state.gridA || state.simW === 0) return;
          for (var i = 0; i < 4; i++) stepReaction(state);
          var simW = state.simW, simH = state.simH;
          var A = state.gridA, B = state.gridB;
          charRender(obj.ctx, w, h, obj.cols, obj.rows, function (c, r, cols, rows) {
            var sx = Math.floor(c / 2);
            var sy = Math.floor(r / 2);
            if (sx >= simW) sx = simW - 1;
            if (sy >= simH) sy = simH - 1;
            var idx = sy * simW + sx;
            return 1.0 - B[idx];
          });
        }

        // 6. Voronoi — animated tessellation with highlighted boundaries
        function drawVoronoi(obj, s) {
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          var seeds = obj.state.seeds;
          var dt = 0.002;
          for (var i = 0; i < seeds.length; i++) {
            var sd = seeds[i];
            sd.x += sd.vx * dt;
            sd.y += sd.vy * dt;
            if (sd.x < 0 || sd.x > 1) { sd.vx *= -1; sd.x = Math.max(0, Math.min(1, sd.x)); }
            if (sd.y < 0 || sd.y > 1) { sd.vy *= -1; sd.y = Math.max(0, Math.min(1, sd.y)); }
          }
          pixelRender(obj.ctx, w, h, obj.cols, obj.rows, function (c, r, cols, rows) {
            var x = c / cols, y = r / rows;
            var min1 = 1e9, min2 = 1e9, closest = 0;
            for (var i = 0; i < seeds.length; i++) {
              var dx = x - seeds[i].x, dy = y - seeds[i].y;
              var d = dx * dx + dy * dy;
              if (d < min1) { min2 = min1; min1 = d; closest = i; }
              else if (d < min2) { min2 = d; }
            }
            var d1 = Math.sqrt(min1), d2 = Math.sqrt(min2);
            var edge = d2 - d1;
            var isEdge = edge < 0.02 ? 1.0 : 0.0;
            var cellShade = (closest * 0.0618) % 1.0;
            return isEdge * 0.85 + (1 - isEdge) * cellShade * 0.35;
          });
        }

        // 7. Lissajous Web — parametric curves with persistent fading trail
        function drawLissajous(obj, s) {
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          var trail = obj.state.trail;
          if (!trail || trail.length !== obj.cols * obj.rows) {
            trail = new Float32Array(obj.cols * obj.rows);
            obj.state.trail = trail;
          }
          for (var i = 0; i < trail.length; i++) trail[i] *= 0.96;
          var curves = 5;
          for (var k = 0; k < curves; k++) {
            var a = 3 + k;
            var b = 2 + k * 0.7;
            var phase = k * 1.2 + s * 0.3;
            var points = 600;
            for (var p = 0; p < points; p++) {
              var t = (p / points) * Math.PI * 2;
              var px = Math.sin(a * t + phase) * 0.42 + 0.5;
              var py = Math.sin(b * t + phase * 0.7) * 0.42 + 0.5;
              var gc = Math.floor(px * obj.cols);
              var gr = Math.floor(py * obj.rows);
              if (gc >= 0 && gc < obj.cols && gr >= 0 && gr < obj.rows) {
                var idx = gr * obj.cols + gc;
                trail[idx] = Math.min(trail[idx] + 0.3, 1.0);
              }
            }
          }
          charRender(obj.ctx, w, h, obj.cols, obj.rows, function (c, r, cols, rows) {
            return trail[r * cols + c];
          });
        }

        // 8. Fractal Zoom — Mandelbrot boundary with oscillating viewport
        function drawFractal(obj, s) {
          var w = obj.parent.offsetWidth;
          var h = obj.parent.offsetHeight;
          var aspect = h / w;
          var zoom = 2.5 + Math.sin(s * 0.15) * 1.5;
          var cx = -0.745 + Math.sin(s * 0.07) * 0.1;
          var cy = 0.186 + Math.cos(s * 0.09) * 0.1;
          var maxIter = 40;
          pixelRender(obj.ctx, w, h, obj.cols, obj.rows, function (c, r, cols, rows) {
            var x0 = cx + (c / cols - 0.5) * zoom;
            var y0 = cy + (r / rows - 0.5) * zoom * aspect;
            var x = 0, y = 0, iter = 0;
            while (x * x + y * y <= 4 && iter < maxIter) {
              var xn = x * x - y * y + x0;
              y = 2 * x * y + y0;
              x = xn;
              iter++;
            }
            if (iter === maxIter) return 0;
            var smooth = iter - Math.log(Math.log(x * x + y * y) / Math.log(2)) / Math.log(2);
            return (smooth / maxIter);
          });
        }

        var animFns = {
          plasma: drawPlasma,
          topo: drawTopo,
          moire: drawMoire,
          tunnel: drawTunnel,
          reaction: drawReaction,
          voronoi: drawVoronoi,
          lissajous: drawLissajous,
          fractal: drawFractal
        };

        document.querySelectorAll('.section-canvas').forEach(function (el) {
          initCanvas(el);
        });

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            var canvas = entry.target.querySelector('.section-canvas');
            if (!canvas) return;
            for (var i = 0; i < instances.length; i++) {
              if (instances[i].canvas === canvas) {
                instances[i].visible = entry.isIntersecting;
                break;
              }
            }
          });
        }, { threshold: 0.0 });

        document.querySelectorAll('.has-canvas').forEach(function (el) {
          observer.observe(el);
        });

        window.addEventListener('resize', function () {
          for (var i = 0; i < instances.length; i++) sizeCanvas(instances[i]);
        });

        function loop(t) {
          var s = t * 0.001;
          for (var i = 0; i < instances.length; i++) {
            var obj = instances[i];
            if (!obj.visible) continue;
            var fn = animFns[obj.anim];
            if (fn) fn(obj, s);
          }
          requestAnimationFrame(loop);
        }
        requestAnimationFrame(loop);

        document.querySelectorAll('[data-request-access]').forEach(function (el) {
          el.addEventListener('click', function (e) {
            e.preventDefault();
            var modal = document.getElementById('request-access-modal');
            if (modal) {
              modal.showModal();
            } else {
              window.location.href = '/?request=true';
            }
          });
        });
      })();
    </script>

  </body>
</html>

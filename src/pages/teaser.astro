---
import '../styles/global.css';

const title = 'Ultraviolet';
const description = 'From product discovery to pull request.';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oxygen+Mono&family=Work+Sans:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="grid-bg"></div>
    <div class="noise"></div>

    <main style="position:relative;z-index:10;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;">
      <div style="text-align:center;max-width:560px;">
        <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-dim);margin-bottom:24px;">Private Beta</div>

        <h1 style="font-family:var(--font-logo);font-weight:var(--logo-weight);font-size:clamp(28px,5vw,42px);letter-spacing:0.2em;text-transform:uppercase;line-height:1;margin:0 0 24px 0;color:var(--text-primary);">
          Ultraviolet
        </h1>

        <p style="font-size:16px;line-height:1.6;color:var(--text-secondary);max-width:400px;margin:0 auto 40px;">
          From product discovery to pull request. The system that turns product decisions into shipped software.
        </p>

        <div style="display:flex;gap:16px;align-items:center;justify-content:center;flex-wrap:wrap;">
          <a href="/login" style="padding:12px 24px;font-family:var(--font-mono);font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);text-decoration:none;border:1px solid var(--border-strong);transition:color 0.2s,border-color 0.2s;">
            Log in
          </a>
          <button type="button" data-request-access style="padding:12px 24px;font-family:var(--font-mono);font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;background:var(--text-primary);color:var(--bg-primary);border:none;cursor:pointer;transition:opacity 0.15s;">
            Request Access
          </button>
        </div>
      </div>
    </main>

    <dialog id="request-access-modal" aria-labelledby="request-access-title" style="position:fixed;inset:0;z-index:10000;width:100%;max-width:100%;height:100%;max-height:100%;padding:24px;background:transparent;border:none;box-sizing:border-box;">
      <div data-modal-backdrop style="position:absolute;inset:0;background:rgba(0,0,0,0.55);backdrop-filter:blur(4px);"></div>
      <div style="position:relative;width:100%;max-width:460px;background:var(--bg-secondary);border:1px solid var(--border-strong);border-radius:8px;padding:36px 32px;box-shadow:0 20px 60px rgba(0,0,0,0.35);">
        <button type="button" data-modal-close aria-label="Close" style="position:absolute;top:14px;right:14px;width:32px;height:32px;background:transparent;color:var(--text-secondary);border:none;font-size:20px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;border-radius:4px;">&times;</button>
        <div style="font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:0.2em;color:var(--text-dim);margin-bottom:12px;">Private Beta</div>
        <h2 id="request-access-title" class="font-display" style="font-size:28px;line-height:1.15;margin:0 0 10px 0;color:var(--text-primary);font-weight:400;">Request access</h2>
        <p style="font-size:14px;line-height:1.55;color:var(--text-secondary);margin:0 0 24px 0;">Tell us where you work and we'll be in touch.</p>
        <form id="request-access-form" novalidate>
          <div style="margin-bottom:16px;">
            <label for="ra-company" style="display:block;font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:0.15em;color:var(--text-dim);margin-bottom:6px;">Company</label>
            <input id="ra-company" name="company" type="text" autocomplete="organization" required style="width:100%;padding:12px 14px;background:var(--bg-tertiary);color:var(--text-primary);border:1px solid var(--border-strong);border-radius:4px;font-family:var(--font-mono);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div style="margin-bottom:20px;">
            <label for="ra-email" style="display:block;font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:0.15em;color:var(--text-dim);margin-bottom:6px;">Email</label>
            <input id="ra-email" name="email" type="email" autocomplete="email" required style="width:100%;padding:12px 14px;background:var(--bg-tertiary);color:var(--text-primary);border:1px solid var(--border-strong);border-radius:4px;font-family:var(--font-mono);font-size:13px;outline:none;box-sizing:border-box;" />
          </div>
          <div id="ra-message" style="display:none;font-family:var(--font-mono);font-size:11px;letter-spacing:0.05em;margin-bottom:14px;padding:10px 12px;border-radius:4px;"></div>
          <button type="submit" style="width:100%;padding:14px 24px;font-family:var(--font-mono);font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;background:var(--text-primary);color:var(--bg-primary);border:none;cursor:pointer;border-radius:4px;transition:opacity 0.15s;">Request access</button>
        </form>
      </div>
    </dialog>
    <style>
      dialog#request-access-modal::backdrop { display: none; }
      dialog#request-access-modal[open] { display: flex; align-items: center; justify-content: center; }
    </style>
    <script is:inline>
      (function () {
        var modal = document.getElementById('request-access-modal');
        var form = document.getElementById('request-access-form');
        var submitBtn = form.querySelector('button[type="submit"]');
        var msg = document.getElementById('ra-message');
        var companyInput = document.getElementById('ra-company');
        var emailInput = document.getElementById('ra-email');
        var triggerEl = null;
        var closeTimerId = null;

        function openModal(trigger) {
          if (closeTimerId) { clearTimeout(closeTimerId); closeTimerId = null; }
          triggerEl = trigger || null;
          resetForm();
          modal.showModal();
          companyInput.focus();
        }

        function closeModal() {
          if (closeTimerId) { clearTimeout(closeTimerId); closeTimerId = null; }
          modal.close();
          if (triggerEl && triggerEl.focus) { triggerEl.focus(); }
          triggerEl = null;
        }

        function resetForm() {
          form.reset();
          msg.style.display = 'none';
          msg.textContent = '';
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          submitBtn.textContent = 'Request access';
        }

        function showMessage(text, kind) {
          msg.textContent = text;
          msg.style.display = 'block';
          if (kind === 'error') {
            msg.style.background = 'rgba(220, 38, 38, 0.12)';
            msg.style.color = '#dc2626';
          } else {
            msg.style.background = 'rgba(34, 197, 94, 0.12)';
            msg.style.color = '#16a34a';
          }
        }

        document.querySelectorAll('[data-request-access]').forEach(function (el) {
          el.addEventListener('click', function (e) {
            e.preventDefault();
            openModal(e.currentTarget);
          });
        });

        modal.querySelectorAll('[data-modal-close], [data-modal-backdrop]').forEach(function (el) {
          el.addEventListener('click', closeModal);
        });

        modal.addEventListener('cancel', function (e) {
          e.preventDefault();
          closeModal();
        });

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var company = companyInput.value.trim();
          var email = emailInput.value.trim();

          if (!company) {
            showMessage('Please enter your company name', 'error');
            companyInput.focus();
            return;
          }
          if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            showMessage('Please enter a valid email address', 'error');
            emailInput.focus();
            return;
          }

          msg.style.display = 'none';
          submitBtn.disabled = true;
          submitBtn.style.opacity = '0.6';
          submitBtn.textContent = 'Submitting...';

          fetch('/api/request-access', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ company: company, email: email }),
          })
            .then(function (res) {
              return res.json().then(function (data) { return { ok: res.ok, data: data }; });
            })
            .then(function (result) {
              if (!result.ok) {
                throw new Error((result.data && result.data.error) || 'Something went wrong');
              }
              showMessage('Thanks \u2014 we\u2019ll be in touch soon.', 'success');
              submitBtn.textContent = 'Done';
              closeTimerId = setTimeout(closeModal, 2200);
            })
            .catch(function (err) {
              showMessage(err.message || 'Something went wrong', 'error');
              submitBtn.disabled = false;
              submitBtn.style.opacity = '1';
              submitBtn.textContent = 'Request access';
            });
        });
      })();
    </script>
  </body>
</html>

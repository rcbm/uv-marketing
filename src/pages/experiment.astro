    <script is:inline>
      (function () {
        var canvas = document.getElementById('ascii-bg');
        var ctx = canvas.getContext('2d');

        var CELL = 14;
        var chars = [' ', '·', '░', '▒', '▓', '█'];
        var grays = [
          '#0a0a0a',
          '#1e1e1e',
          '#3a3a3a',
          '#5c5c5c',
          '#888888',
          '#b0b0b0'
        ];

        var cols, rows;

        function resize() {
          var dpr = window.devicePixelRatio || 1;
          canvas.width = window.innerWidth * dpr;
          canvas.height = window.innerHeight * dpr;
          canvas.style.width = window.innerWidth + 'px';
          canvas.style.height = window.innerHeight + 'px';
          ctx.scale(dpr, dpr);
          cols = Math.ceil(window.innerWidth / CELL) + 1;
          rows = Math.ceil(window.innerHeight / CELL) + 1;
        }

        resize();
        window.addEventListener('resize', resize);

        function draw(t) {
          var s = t * 0.001;
          var w = window.innerWidth;
          var h = window.innerHeight;

          ctx.clearRect(0, 0, w, h);
          ctx.font = CELL + 'px Oxygen Mono, monospace';
          ctx.textBaseline = 'top';

          var buckets = [];
          for (var i = 0; i < chars.length; i++) {
            buckets[i] = [];
          }

          for (var r = 0; r < rows; r++) {
            for (var c = 0; c < cols; c++) {
              var x = c / cols;
              var y = r / rows;

              var v1 = Math.sin(x * 8.0 + s * 0.35) * 0.5 + 0.5;
              var v2 = Math.sin(y * 6.0 + s * 0.25) * 0.5 + 0.5;
              var v3 = Math.sin((x + y) * 5.0 + s * 0.18) * 0.5 + 0.5;

              var cx = x - 0.5;
              var cy = y - 0.5;
              var dist = Math.sqrt(cx * cx + cy * cy);
              var v4 = Math.sin(dist * 12.0 - s * 0.45) * 0.5 + 0.5;

              var v5 = Math.sin(x * 3.0 - s * 0.12) * Math.sin(y * 4.0 + s * 0.2) * 0.5 + 0.5;

              var brightness = (v1 + v2 + v3 + v4 + v5) / 5.0;

              var level = Math.floor(brightness * 5.99);
              if (level > 5) level = 5;
              if (level < 0) level = 0;

              buckets[level].push(c * CELL, r * CELL);
            }
          }

          for (var lvl = 0; lvl < chars.length; lvl++) {
            if (buckets[lvl].length === 0) continue;
            ctx.fillStyle = grays[lvl];
            var ch = chars[lvl];
            var arr = buckets[lvl];
            for (var j = 0; j < arr.length; j += 2) {
              ctx.fillText(ch, arr[j], arr[j + 1]);
            }
          }

          requestAnimationFrame(draw);
        }

        requestAnimationFrame(draw);

        document.querySelectorAll('[data-request-access]').forEach(function (el) {
          el.addEventListener('click', function (e) {
            e.preventDefault();
            var modal = document.getElementById('request-access-modal');
            if (modal) {
              modal.showModal();
            } else {
              window.location.href = '/?request=true';
            }
          });
        });
      })();
    </script>


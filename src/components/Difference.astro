---
const cards = [
  {
    title: 'Not a chatbot',
    body: 'AI assistants suggest code. You still have to write it, test it, review it. Ultraviolet executes the entire workflow—spec to merged PR—without manual intervention.',
  },
  {
    title: 'Not a black box',
    body: 'Every decision is visible. Every file change is logged. You can pause execution, inject hints, or take over at any point. Full audit trails for SOC2 and HIPAA.',
  },
  {
    title: 'Not starting from scratch',
    body: 'Generic tools re-learn your codebase on every task. Ultraviolet maintains persistent context—your patterns, conventions, and architectural decisions.',
  },
  {
    title: 'Not replacing engineers',
    body: 'Ultraviolet handles the 80% that\'s routine. Your engineers focus on novel architecture, performance optimization, and the problems that actually need them.',
  },
];
---

<section class="py-[120px] px-10 border-t border-border">
  <div class="max-w-[1200px] mx-auto">
    <div class="max-w-[600px] mb-20">
      <div class="font-mono text-[11px] tracking-[0.15em] uppercase text-text-dim mb-5">The Difference</div>
      <h2 class="font-display heading-style text-[clamp(32px,4vw,48px)] leading-tight">
        Autonomy with guardrails.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {cards.map((card) => (
        <div class="p-12 border border-border transition-colors hover:border-border-strong">
          <h3 class="font-display heading-style text-2xl mb-4">{card.title}</h3>
          <p class="text-text-secondary text-base leading-relaxed">{card.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

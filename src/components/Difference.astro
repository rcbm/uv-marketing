---
const cards = [
  {
    title: 'Product-to-production',
    body: 'This is not a tool that helps engineers write code faster. It\'s a system that turns product decisions into shipped features\u2014from problem definition through pull request.',
  },
  {
    title: 'Structured, not conversational',
    body: 'No blank pages. No prompt engineering. A guided workflow that captures intent, generates structured artifacts\u2014PRDs, specs, task graphs\u2014and produces executable plans.',
  },
  {
    title: 'Persistent, not ephemeral',
    body: 'Every decision, spec, and artifact persists across sessions. Context compounds over time. Your patterns, conventions, and architectural decisions are never lost.',
  },
  {
    title: 'Orchestrated, not manual',
    body: 'You don\'t manage the workflow. The system sequences work, maps dependencies, coordinates execution, and produces ready-to-review pull requests.',
  },
];
---

<section class="py-[120px] px-10 border-t border-border">
  <div class="max-w-[1200px] mx-auto">
    <div class="max-w-[600px] mb-20">
      <div class="font-mono text-[11px] tracking-[0.15em] uppercase text-text-dim mb-5">The Difference</div>
      <h2 class="font-display heading-style text-[clamp(32px,4vw,48px)] leading-tight">
        Not a coding tool. A delivery system.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {cards.map((card) => (
        <div class="p-12 border border-border transition-colors hover:border-border-strong">
          <h3 class="font-display heading-style text-2xl mb-4">{card.title}</h3>
          <p class="text-text-secondary text-base leading-relaxed">{card.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

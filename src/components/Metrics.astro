---
const metrics = [
  { value: 'Hours', label: 'Idea to pull request' },
  { value: '0', label: 'Context lost between steps' },
  { value: '100%', label: 'Decision traceability' },
  { value: '1', label: 'System, not five tools' },
];
---

<section class="py-20 px-10 border-t border-border">
  <div class="max-w-[1200px] mx-auto grid grid-cols-2 lg:grid-cols-4 gap-12 max-sm:gap-8">
    {metrics.map((m) => (
      <div class="text-center">
        <div class="font-display heading-style text-5xl mb-2">{m.value}</div>
        <div class="font-mono text-[10px] tracking-[0.1em] uppercase text-text-secondary">{m.label}</div>
      </div>
    ))}
  </div>
</section>

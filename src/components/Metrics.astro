---
const metrics = [
  { value: '60-70%', label: 'Lower AI costs' },
  { value: '95%+', label: 'Pattern consistency' },
  { value: '~$30', label: 'Per feature' },
  { value: '8-16hrs', label: 'Spec to PR' },
];
---

<section class="py-20 px-10 border-t border-border">
  <div class="max-w-[1200px] mx-auto grid grid-cols-2 lg:grid-cols-4 gap-12 max-sm:gap-8">
    {metrics.map((m) => (
      <div class="text-center">
        <div class="font-display text-5xl italic mb-2">{m.value}</div>
        <div class="font-mono text-[10px] tracking-[0.1em] uppercase text-text-secondary">{m.label}</div>
      </div>
    ))}
  </div>
</section>
